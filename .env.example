# Banco (local: docker-compose; prod: Neon — DATABASE_URL pooled, DIRECT_URL direta)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME?schema=public"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME?schema=public"

LLM_PROVIDER="gemini"
GEMINI_API_KEY=
GEMINI_MODEL="gemini-2.5-flash"
GEMINI_BASE_URL="https://generativelanguage.googleapis.com/v1beta"
# >= 90000 recomendado para LONGO
GEMINI_TIMEOUT_MS="120000"
# Teto global de timeout (ms). Em Vercel Hobby (função morre em 60s) usar 55000
# para nenhuma chamada LLM ultrapassar o limite. Vazio em dev = sem teto.
# LLM_MAX_TIMEOUT_MS="55000"

AUTH_SECRET="gere-com: npx auth secret"
AUTH_TRUST_HOST="true"

# Quotas diárias do beta (defaults no código: 10 / 20)
DAILY_GENERATION_LIMIT="10"
DAILY_REGENERATION_LIMIT="20"

# Sentry (vazio = desligado)
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
# SENTRY_AUTH_TOKEN=""  # só no CI/Vercel, para source maps
