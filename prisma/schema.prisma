generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String       @id @default(cuid())
  email     String       @unique
  name      String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  briefings Briefing[]
  profile   UserProfile?
}

model Briefing {
  id              String   @id @default(cuid())
  userId          String
  goal            String
  audience        String
  audienceLevel   String
  offer           String
  differentiation String
  tone            String[]
  avoid           String[]
  cta             String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UserProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  roleTitle     String?
  whatIDo       String?
  howIWork      String?
  niche         String?
  audience      String?
  audienceLevel String?
  languageStyle String?
  goals         String?
  constraints   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
